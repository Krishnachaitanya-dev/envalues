# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get from: Supabase Dashboard → Settings → API

SUPABASE_URL=https://tbfmturpclqponehhdjq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ⚠️ IMPORTANT: Use SERVICE_ROLE_KEY (not ANON_KEY!)
# Service Role Key bypasses Row Level Security (needed for backend)
# Find it in: Dashboard → Settings → API → service_role (secret)


# ============================================
# WHATSAPP BUSINESS API CONFIGURATION
# ============================================
# Get from: Meta Business Manager → WhatsApp

# API URL (keep as-is)
WHATSAPP_API_URL=https://graph.facebook.com/v21.0

# Phone Number ID
# Location: Meta Business → WhatsApp → Phone Number → Copy Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here

# Access Token
# Location: Meta Business → System Users → Create User → Generate Token
# Permissions needed: whatsapp_business_messaging
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here

# Verify Token (YOU create this - any random secure string)
# Use the same value when setting up webhook in Meta
# Example: chatbot-verify-2024 or my-secret-token-xyz123
WHATSAPP_VERIFY_TOKEN=chatbot-verify-2024


# ============================================
# NOTES
# ============================================

# 1. This .env file is for REFERENCE ONLY
#    Do NOT use it directly in production!

# 2. For Edge Functions, set secrets using CLI:
#    supabase secrets set KEY=VALUE

# 3. Example commands:
#    supabase secrets set SUPABASE_URL=https://tbfmturpclqponehhdjq.supabase.co
#    supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-key-here
#    supabase secrets set WHATSAPP_API_URL=https://graph.facebook.com/v21.0
#    supabase secrets set WHATSAPP_PHONE_NUMBER_ID=123456789
#    supabase secrets set WHATSAPP_ACCESS_TOKEN=your-token
#    supabase secrets set WHATSAPP_VERIFY_TOKEN=chatbot-verify-2024

# 4. Never commit this file to Git!
#    It's already in .gitignore